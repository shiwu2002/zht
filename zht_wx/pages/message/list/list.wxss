/* pages/message/list/list.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.conversation-list {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.conversation-item {
  display: flex;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: all 0.3s;
}

.conversation-item:active {
  background: #f9f9f9;
}

.conversation-item:last-child {
  border-bottom: none;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.conversation-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
}

.conversation-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.username {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.time {
  font-size: 24rpx;
  color: #999999;
}

.conversation-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.content {
  font-size: 26rpx;
  color: #666666;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.content.unread {
  color: #333333;
  font-weight: bold;
}

.badge {
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  background: #ff4444;
  color: #ffffff;
  font-size: 22rpx;
  border-radius: 16rpx;
  padding: 0 12rpx;
  margin-left: 12rpx;
}

.empty {
  text-align: center;
  padding: 100rpx 20rpx;
  color: #999999;
  font-size: 28rpx;
}
