/* pages/message/list/list.wxss */
.container {
  padding-bottom: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* Tab 切换栏 */
.tab-bar {
  display: flex;
  background: #ffffff;
  padding: 20rpx 30rpx;
  margin: 20rpx;
  border-radius: 16rpx;
  gap: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666666;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: #07c160;
  color: #ffffff;
  font-weight: bold;
}

/* 区块标题 */
.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
  color: #999999;
}

.section-title .count {
  background: #07c160;
  color: #ffffff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
}

/* 消息列表 */
.message-section,
.review-section {
  margin: 0 20rpx 20rpx;
}

.conversation-list {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.conversation-item {
  display: flex;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: all 0.3s;
}

.conversation-item:active {
  background: #f9f9f9;
}

.conversation-item:last-child {
  border-bottom: none;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.conversation-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
}

.conversation-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.username {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.time {
  font-size: 24rpx;
  color: #999999;
}

.conversation-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.content {
  font-size: 26rpx;
  color: #666666;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.content.unread {
  color: #333333;
  font-weight: bold;
}

.badge {
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  background: #ff4444;
  color: #ffffff;
  font-size: 22rpx;
  border-radius: 16rpx;
  padding: 0 12rpx;
  margin-left: 12rpx;
}

/* 评价列表 */
.review-list {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.review-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: all 0.3s;
}

.review-item:active {
  background: #f9f9f9;
}

.review-item:last-child {
  border-bottom: none;
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.review-type {
  background: #07c160;
  color: #ffffff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.review-time {
  font-size: 24rpx;
  color: #999999;
}

.review-content {
  margin-bottom: 16rpx;
}

.rating {
  margin-bottom: 8rpx;
}

.star {
  font-size: 32rpx;
  color: #ff9800;
}

.review-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  display: block;
}

.review-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.reviewer {
  font-size: 24rpx;
  color: #999999;
}

.empty {
  text-align: center;
  padding: 100rpx 20rpx;
  color: #999999;
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
}
