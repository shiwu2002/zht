/* pages/message/chat.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

.message-list {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

.message-item {
  display: flex;
  margin-bottom: 30rpx;
}

.message-item.self {
  flex-direction: row-reverse;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.message-content {
  max-width: 60%;
  padding: 20rpx;
  border-radius: 12rpx;
  position: relative;
}

.message-item.other .message-content {
  background: #ffffff;
  margin-left: 20rpx;
  border-top-left-radius: 4rpx;
}

.message-item.self .message-content {
  background: #95ec69;
  margin-right: 20rpx;
  border-top-right-radius: 4rpx;
}

.message-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
  word-break: break-all;
}

.message-time {
  font-size: 22rpx;
  color: #999999;
  display: block;
  margin-top: 8rpx;
  text-align: right;
}

.input-bar {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #ffffff;
  border-top: 1rpx solid #e5e5e5;
  gap: 20rpx;
}

.input {
  flex: 1;
  padding: 16rpx 24rpx;
  background: #f5f5f5;
  border-radius: 24rpx;
  font-size: 28rpx;
}

.send-btn {
  padding: 16rpx 32rpx;
  background: #07c160;
  color: #ffffff;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: bold;
}
