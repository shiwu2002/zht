/* pages/category/category.wxss */
.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 30rpx;
}

.category-card {
  width: calc(33.33% - 20rpx);
  background: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.category-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.category-name {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.category-count {
  font-size: 22rpx;
  color: #999999;
}
