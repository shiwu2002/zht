/* pages/category/category.wxss */
.container {
  padding: 0 20rpx 40rpx;
  background: #f3f3f3;
  min-height: 100vh;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 0;
  position: sticky;
  top: 0;
  z-index: 100;
  background: #f3f3f3;
}

.search-input {
  display: flex;
  align-items: center;
  height: 80rpx;
  background: #ffffff;
  border-radius: 40rpx;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 区块标题 */
.section-title {
  display: flex;
  align-items: center;
  padding: 30rpx 10rpx 20rpx;
}

.title-line {
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(180deg, #07c160 0%, #06ad56 100%);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.title-count {
  font-size: 24rpx;
  color: #999;
}

/* 分类网格 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.category-card {
  width: calc(25% - 15rpx);
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.2s, box-shadow 0.2s;
}

.category-card:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

/* 图标容器 */
.icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  font-size: 48rpx;
}

/* 各类图标背景色 */
.icon-book {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.icon-digital {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
}

.icon-clothes {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.icon-life {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.icon-sport {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.icon-food {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

.icon-beauty {
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%);
}

.icon-other {
  background: linear-gradient(135deg, #e0e0e0 0%, #f5f5f5 100%);
}

.iconfont {
  font-style: normal;
}

/* 分类名称 */
.category-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

/* 分类底部 */
.category-footer {
  display: flex;
  align-items: baseline;
}

.category-count {
  font-size: 24rpx;
  font-weight: bold;
  color: #07c160;
}

.category-unit {
  font-size: 20rpx;
  color: #999;
  margin-left: 4rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
