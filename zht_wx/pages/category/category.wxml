<!--pages/category/category.wxml-->
<view class="container">
  
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input">
      <text class="search-icon">🔍</text>
      <input class="input" placeholder="搜索分类" bindinput="onSearch" />
    </view>
  </view>

  <!-- 全部分类 -->
  <view class="section-title">
    <view class="title-line"></view>
    <text class="title-text">全部分类</text>
    <text class="title-count">{{categories.length}}个分类</text>
  </view>

  <!-- 分类网格 -->
  <view class="category-grid">
    <view class="category-card" wx:for="{{filteredCategories}}" wx:key="id" 
          data-id="{{item.id}}" data-name="{{item.name}}" bindtap="onCategoryTap">
      <view class="icon-wrapper {{'icon-' + item.iconClass}}">
        <text class="iconfont">{{item.iconUnicode || '📦'}}</text>
      </view>
      <text class="category-name">{{item.name}}</text>
      <view class="category-footer">
        <text class="category-count">{{item.count || 0}}</text>
        <text class="category-unit">件</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{filteredCategories.length === 0}}">
    <text class="empty-icon">😕</text>
    <text class="empty-text">暂无相关分类</text>
  </view>

</view>
