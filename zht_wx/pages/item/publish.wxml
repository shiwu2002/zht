<!--pages/item/publish.wxml-->
<view class="container">
  <view class="form">
    <!-- 图片上传 -->
    <view class="form-item">
      <text class="label">物品图片</text>
      <view class="image-uploader">
        <view class="image-item" wx:for="{{images}}" wx:key="*this">
          <image class="image" src="{{item}}" mode="aspectFill"></image>
          <view class="delete-btn" catchtap="deleteImage" data-index="{{index}}">×</view>
        </view>
        <view class="upload-btn" bindtap="uploadImage" wx:if="{{images.length < 9}}">
          <text>+</text>
        </view>
      </view>
    </view>

    <!-- 标题 -->
    <view class="form-item">
      <text class="label">标题</text>
      <input class="input" placeholder="请输入标题" value="{{title}}" bindinput="onTitleInput" maxlength="50" />
    </view>

    <!-- 分类 -->
    <view class="form-item">
      <text class="label">分类</text>
      <picker mode="selector" range="{{categories}}" range-key="name" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="picker">{{categories[categoryIndex] ? categories[categoryIndex].name : '请选择分类'}}</view>
      </picker>
    </view>

    <!-- 描述 -->
    <view class="form-item">
      <text class="label">描述</text>
      <textarea class="textarea" placeholder="请详细描述物品" value="{{description}}" bindinput="onDescInput" maxlength="500" />
    </view>

    <!-- 交换方式 -->
    <view class="form-item">
      <text class="label">交换方式</text>
      <picker mode="selector" range="{{exchangeTypes}}" value="{{exchangeIndex}}" bindchange="onExchangeChange">
        <view class="picker">{{exchangeTypes[exchangeIndex]}}</view>
      </picker>
    </view>

    <!-- 价格 -->
    <view class="form-item">
      <text class="label">估价 (元)</text>
      <input class="input" type="digit" placeholder="请输入估价" value="{{price}}" bindinput="onPriceInput" />
    </view>

    <!-- 位置 -->
    <view class="form-item">
      <text class="label">位置</text>
      <view class="location-row" bindtap="getLocation">
        <text class="location-text">{{location || '点击获取位置'}}</text>
        <text class="arrow">></text>
      </view>
    </view>

    <!-- 标签 -->
    <view class="form-item">
      <text class="label">标签</text>
      <input class="input" placeholder="多个标签用逗号分隔" value="{{tags}}" bindinput="onTagsInput" />
    </view>

    <button class="submit-btn" bindtap="onSubmit" loading="{{loading}}">发布</button>
  </view>
</view>
