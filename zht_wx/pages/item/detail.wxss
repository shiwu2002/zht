/* pages/item/detail.wxss */
.container {
  padding-bottom: 140rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.image-swiper {
  width: 100%;
  height: 700rpx;
}

.slide-image {
  width: 100%;
  height: 100%;
}

.info-section {
  background: #ffffff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.price-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.price {
  font-size: 44rpx;
  color: #ff4444;
  font-weight: bold;
  margin-right: 20rpx;
}

.exchange-type {
  font-size: 24rpx;
  color: #07c160;
  background: #e8f9f0;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.location, .time {
  font-size: 26rpx;
  color: #999999;
  display: block;
  margin-bottom: 10rpx;
}

.desc-section {
  background: #ffffff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.desc-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.seller-section {
  display: flex;
  align-items: center;
  background: #ffffff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.seller-info {
  flex: 1;
}

.nickname {
  font-size: 30rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.credit {
  font-size: 24rpx;
  color: #999999;
}

.arrow {
  color: #cccccc;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #ffffff;
  border-top: 1rpx solid #eeeeee;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
  font-size: 22rpx;
  color: #666666;
}

.exchange-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: #07c160;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 30rpx;
}
