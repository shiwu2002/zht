/* pages/item/publish.wxss */
.container {
  padding: 0;
  background: #f3f3f3;
  min-height: 100vh;
}

.form {
  padding: 30rpx 20rpx;
}

.form-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.form-section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
}

.form-section-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #07c160 0%, #06ad56 100%);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 20rpx;
  color: #333;
}

.required::before {
  content: '*';
  color: #ff4444;
  margin-right: 8rpx;
}

.input, .textarea {
  width: 100%;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  border: 1rpx solid transparent;
  transition: all 0.3s;
}

.input:focus, .textarea:focus {
  background: #ffffff;
  border-color: #07c160;
}

.textarea {
  height: 240rpx;
  line-height: 1.6;
}

.picker {
  height: 96rpx;
  line-height: 96rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid transparent;
  transition: all 0.3s;
}

.picker:active {
  background: #ffffff;
  border-color: #07c160;
}

/* 图片上传 */
.image-uploader {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f8f8f8;
}

.image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 48rpx;
  height: 48rpx;
  line-height: 46rpx;
  text-align: center;
  background: rgba(255, 68, 68, 0.9);
  color: #ffffff;
  border-radius: 50%;
  font-size: 32rpx;
  font-weight: bold;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  line-height: 200rpx;
  text-align: center;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 64rpx;
  color: #07c160;
  border: 2rpx dashed #07c160;
  box-sizing: border-box;
}

.upload-btn:active {
  background: rgba(7, 193, 96, 0.1);
}

.upload-hint {
  width: 100%;
  text-align: center;
  font-size: 22rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 位置选择 */
.location-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 96rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
}

.location-text {
  font-size: 28rpx;
  color: #666;
}

.location-text.has-value {
  color: #333;
}

.arrow {
  color: #ccc;
  font-size: 32rpx;
}

/* 提交按钮 */
.submit-wrapper {
  padding: 0 20rpx 40rpx;
}

.submit-btn {
  height: 96rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #ffffff;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.submit-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.submit-btn[loading] {
  opacity: 0.7;
}

/* 提示文字 */
.hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}
