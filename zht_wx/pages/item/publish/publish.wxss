/* pages/item/publish/publish.wxss */
.container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.form-section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.form-section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 32rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.label.required::before {
  content: '* ';
  color: #ff4444;
}

.input, .textarea, .picker {
  width: 100%;
  padding: 20rpx 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 1rpx solid transparent;
  transition: all 0.2s;
  line-height: 1.5;
  min-height: 80rpx;
}

.input:focus, .textarea:focus, .picker:focus {
  background: #ffffff;
  border-color: #07c160;
}

.textarea {
  height: 180rpx;
  line-height: 1.6;
  padding-top: 20rpx;
  min-height: auto;
}

.hint {
  font-size: 24rpx;
  color: #999999;
  margin-top: 12rpx;
  text-align: right;
  line-height: 1.4;
}

.char-count {
  font-size: 24rpx;
  color: #999999;
  margin-top: 12rpx;
  text-align: right;
  line-height: 1.4;
}

.upload-hint {
  font-size: 24rpx;
  color: #999999;
  margin-top: 16rpx;
  text-align: center;
  line-height: 1.4;
}

.image-uploader {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #ffffff;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom-left-radius: 12rpx;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  background: #fafafa;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #999999;
  border: 2rpx dashed #e0e0e0;
  box-sizing: border-box;
}

.location-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  min-height: 48rpx;
  border: 1rpx solid transparent;
}

.location-row:active {
  background: #f0f0f0;
}

.location-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-right: 16rpx;
  min-width: 0;
}

.location-text {
  font-size: 28rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.location-text.has-value {
  color: #333333;
}

.location-coords {
  font-size: 22rpx;
  color: #999999;
  white-space: nowrap;
  display: none; /* 隐藏坐标显示，只显示地址 */
}

.arrow {
  font-size: 32rpx;
  color: #cccccc;
  flex-shrink: 0;
}

.submit-wrapper {
  margin-top: 48rpx;
  padding: 0 24rpx;
  position: sticky;
  bottom: 24rpx;
  z-index: 100;
}

.submit-btn {
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #07c160 0%, #05a850 100%);
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
  border: none;
}

.submit-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 位置弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(4rpx);
}

.modal-content {
  width: 90%;
  max-width: 640rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  animation: slideUp 0.3s ease-out;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 32rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
  border-bottom: 1rpx solid #f0f0f0;
}

.header-left {
  display: flex;
  align-items: center;
}

.header-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.6;
}

.modal-close:active {
  opacity: 1;
}

.modal-body {
  padding: 40rpx 32rpx;
}

.location-input-wrapper {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.location-input-wrapper:focus-within {
  background: #ffffff;
  border-color: #07c160;
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.1);
}

.input-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.location-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  padding: 8rpx 0;
  min-height: 40rpx;
}

.location-input::placeholder {
  color: #cccccc;
}

.location-tips {
  display: flex;
  align-items: flex-start;
  background: rgba(7, 193, 96, 0.05);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-top: 16rpx;
}

.tip-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.location-tips text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
  flex: 1;
}

.modal-footer {
  display: flex;
  padding: 24rpx 32rpx 36rpx;
  gap: 16rpx;
  background: #f8f9fa;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.modal-btn:active {
  transform: scale(0.96);
}

.modal-btn-map {
  background: linear-gradient(135deg, #e8f5e9 0%, #f1f8f4 100%);
  color: #07c160;
  border: 2rpx solid #07c160;
}

.modal-btn-map .btn-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
}

.modal-btn-cancel {
  background: #ffffff;
  color: #666666;
  border: 2rpx solid #e0e0e0;
}

.modal-btn-confirm {
  background: linear-gradient(135deg, #07c160 0%, #05a850 100%);
  color: #ffffff;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}
