/* pages/item/publish.wxss */
.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.form {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  font-size: 28rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
  color: #333333;
}

.input, .textarea {
  width: 100%;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea {
  height: 200rpx;
}

.picker {
  height: 88rpx;
  line-height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.image-uploader {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: #ff4444;
  color: #ffffff;
  border-radius: 50%;
  font-size: 28rpx;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  line-height: 200rpx;
  text-align: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 60rpx;
  color: #999999;
}

.location-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
}

.location-text {
  font-size: 28rpx;
  color: #666666;
}

.arrow {
  color: #cccccc;
}

.submit-btn {
  height: 88rpx;
  line-height: 88rpx;
  background: #07c160;
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 60rpx;
}
