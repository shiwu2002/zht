/* pages/item/edit.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.form-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #333333;
  display: block;
  margin-bottom: 16rpx;
}

.required {
  color: #ff4d4f;
}

.input, .textarea {
  width: 100%;
  padding: 16rpx;
  font-size: 28rpx;
  border: 1px solid #e5e5e5;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.textarea {
  height: 200rpx;
}

.picker {
  padding: 16rpx;
  border: 1px solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.picker-value {
  color: #333333;
}

/* 图片上传样式 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom-left-radius: 8rpx;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #cccccc;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 48rpx;
  color: #cccccc;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #999999;
}

/* 位置选择样式 */
.location-wrapper {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  border: 1px solid #e5e5e5;
  border-radius: 8rpx;
}

.location-text {
  font-size: 28rpx;
  color: #333333;
}

.arrow {
  font-size: 32rpx;
  color: #cccccc;
}

/* 提交按钮 */
.submit-btn {
  background: #07c160;
  color: #ffffff;
  font-size: 32rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-top: 20rpx;
}
