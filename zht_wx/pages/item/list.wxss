/* pages/item/list.wxss */
.container { padding: 20rpx; background: #f5f5f5; min-height: 100vh; }
.item-list { display: flex; flex-wrap: wrap; justify-content: space-between; }
.item-card { width: 48%; background: #ffffff; border-radius: 16rpx; overflow: hidden; margin-bottom: 20rpx; }
.item-image { width: 100%; height: 360rpx; }
.item-info { padding: 20rpx; }
.item-title { font-size: 28rpx; font-weight: bold; display: block; margin-bottom: 10rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.item-desc { font-size: 24rpx; color: #999999; display: block; margin-bottom: 16rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.item-meta { display: flex; justify-content: space-between; font-size: 22rpx; color: #999999; }
.empty, .load-more { text-align: center; padding: 30rpx; color: #999999; font-size: 24rpx; }
