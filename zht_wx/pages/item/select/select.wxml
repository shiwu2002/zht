<!--pages/item/select.wxml-->
<view class="container">
  <view class="item-list">
    <view 
      class="item-card {{item.id === excludeId ? 'disabled' : ''}}" 
      wx:for="{{itemList}}" 
      wx:key="id" 
      data-item="{{item}}"
      bindtap="onSelect">
      <image class="item-image" src="{{item.images[0]}}" mode="aspectFill"></image>
      <view class="item-info">
        <text class="item-title">{{item.title}}</text>
        <text class="item-desc">{{item.description}}</text>
        <view class="item-meta">
          <text>📍 {{item.location}}</text>
          <text wx:if="{{item.status === 1}}">在售</text>
          <text wx:elif="{{item.status === 2}}">已下架</text>
        </view>
      </view>
      <view class="select-mask" wx:if="{{item.id === excludeId}}"></view>
    </view>
  </view>
  
  <view class="empty" wx:if="{{itemList.length === 0}}">
    <text>暂无物品</text>
  </view>
  
  <view class="load-more" wx:if="{{loading}}">加载中...</view>
</view>
