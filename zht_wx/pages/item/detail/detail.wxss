/* pages/item/detail/detail.wxss */
.container {
  padding-bottom: 140rpx;
  background: #f3f3f3;
  min-height: 100vh;
}

/* 图片轮播 */
.image-swiper {
  width: 100%;
  height: 600rpx;
  background: #000;
}

.slide-image {
  width: 100%;
  height: 100%;
}

/* 价格栏 */
.price-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  margin: 20rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #fff5f5 0%, #fff 100%);
}

.price-info {
  display: flex;
  align-items: center;
}

.price {
  font-size: 48rpx;
  color: #ff4444;
  font-weight: bold;
  margin-right: 20rpx;
}

.exchange-type {
  font-size: 24rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.action-icons {
  display: flex;
  align-items: center;
}

.action-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 30rpx;
}

.action-icon .icon {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.action-icon .count {
  font-size: 20rpx;
  color: #999;
}

/* 信息区块 */
.info-section {
  padding: 30rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
  line-height: 1.4;
}

.meta-row {
  display: flex;
  justify-content: space-between;
}

.meta-item {
  display: flex;
  align-items: center;
}

.meta-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.meta-text {
  font-size: 26rpx;
  color: #999;
}

/* 描述区块 */
.desc-section {
  padding: 30rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-line {
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #07c160 0%, #06ad56 100%);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.desc-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  display: block;
  white-space: pre-wrap;
}

/* 图片区块 */
.image-section {
  padding: 30rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.detail-image {
  width: calc(33.33% - 11rpx);
  height: 200rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

/* 卖家区块 */
.seller-section {
  padding: 30rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
}

.seller-info-row {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: #f5f5f5;
}

.seller-details {
  flex: 1;
}

.nickname {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.credit-row {
  display: flex;
  align-items: center;
}

.credit-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
}

.credit-score {
  font-size: 28rpx;
  color: #07c160;
  font-weight: 600;
}

.arrow {
  font-size: 40rpx;
  color: #ccc;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx 30rpx;
  background: #ffffff;
  border-top: 1rpx solid #eeeeee;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.bar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
}

.btn-icon {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.btn-text {
  font-size: 22rpx;
  color: #666;
}

.exchange-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #ffffff;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.exchange-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}
