<!--pages/item/detail/detail.wxml-->
<view class="container" wx:if="{{detail}}">
  
  <!-- 图片轮播 -->
  <swiper class="image-swiper" indicator-dots="{{true}}" autoplay="{{true}}" duration="{{500}}">
    <swiper-item wx:for="{{detail.images}}" wx:key="*this">
      <image class="slide-image" src="{{item}}" mode="aspectFill"></image>
    </swiper-item>
  </swiper>

  <!-- 价格和操作栏 -->
  <view class="price-bar card">
    <view class="price-info">
      <text class="price">¥ {{detail.price}}</text>
      <text class="exchange-type" wx:if="{{detail.exchangeType === 1}}">可交换</text>
    </view>
    <view class="action-icons">
      <view class="action-icon" bindtap="onFavorite">
        <image class="icon-img" src="{{isFavorite ? '/images/other/shoucang_shixin.png' : '/images/other/shoucang.png'}}" mode="aspectFit"></image>
        <text class="count">{{detail.favoriteCount}}</text>
      </view>
      <view class="action-icon" bindtap="onShare">
        <image class="icon-img" src="/images/carouseChart/sousuo.png" mode="aspectFit"></image>
        <text class="count">分享</text>
      </view>
      <view class="action-icon" bindtap="onMessage">
        <image class="icon-img" src="/images/other/xiaoxi.png" mode="aspectFit"></image>
        <text class="count">留言</text>
      </view>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="info-section card">
    <text class="title">{{detail.title}}</text>
    <view class="meta-row">
      <view class="meta-item">
        <image class="meta-icon-img" src="/images/classify/home.png" mode="aspectFit"></image>
        <text class="meta-text">{{detail.location}}</text>
      </view>
      <view class="meta-item">
        <image class="meta-icon-img" src="/images/classify/book.png" mode="aspectFit"></image>
        <text class="meta-text">{{detail.createTime}}</text>
      </view>
    </view>
  </view>

  <!-- 物品描述 -->
  <view class="desc-section card">
    <view class="section-header">
      <view class="header-line"></view>
      <text class="section-title">物品描述</text>
    </view>
    <text class="desc-content">{{detail.description}}</text>
  </view>

  <!-- 物品图片 -->
  <view class="image-section card" wx:if="{{detail.images && detail.images.length > 1}}">
    <view class="section-header">
      <view class="header-line"></view>
      <text class="section-title">物品图片</text>
    </view>
    <view class="image-grid">
      <image class="detail-image" wx:for="{{detail.images}}" wx:key="*this" 
             src="{{item}}" mode="aspectFill" bindtap="previewImage" data-index="{{index}}"></image>
    </view>
  </view>

  <!-- 卖家信息 -->
  <view class="seller-section card" bindtap="toSeller">
    <view class="section-header">
      <view class="header-line"></view>
      <text class="section-title">卖家信息</text>
    </view>
    <view class="seller-info-row">
      <image class="avatar" src="{{detail.userAvatar}}" mode="aspectFill"></image>
      <view class="seller-details">
        <text class="nickname">{{detail.userNickname}}</text>
        <view class="credit-row">
          <text class="credit-label">信用分</text>
          <text class="credit-score">{{detail.userCredit}}</text>
        </view>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="action-bar">
    <view class="bar-btn" bindtap="onFavorite">
      <image class="btn-icon-img" src="{{isFavorite ? '/images/other/shoucang_shixin.png' : '/images/other/shoucang.png'}}" mode="aspectFit"></image>
      <text class="btn-text">{{isFavorite ? '已收藏' : '收藏'}}</text>
    </view>
    <view class="bar-btn" bindtap="onMessage">
      <image class="btn-icon-img" src="/images/other/xiaoxi.png" mode="aspectFit"></image>
      <text class="btn-text">消息</text>
    </view>
    <button class="exchange-btn" bindtap="onExchange">发起交换</button>
  </view>

</view>
