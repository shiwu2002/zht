<!--pages/exchange/detail.wxml-->
<view class="container" wx:if="{{detail}}">
  <view class="status-bar">
    <text class="status-text">{{statusMap[detail.status]}}</text>
  </view>

  <view class="section">
    <text class="section-title">交换信息</text>
    <view class="info-row"><text class="label">交换单号:</text><text>{{detail.exchangeNo}}</text></view>
    <view class="info-row"><text class="label">创建时间:</text><text>{{detail.createTime}}</text></view>
  </view>

  <view class="section">
    <text class="section-title">物品信息</text>
    <view class="item-row">
      <text class="label">我提供的:</text>
      <text>{{detail.offerItemTitle}}</text>
    </view>
    <view class="item-row">
      <text class="label">我想换:</text>
      <text>{{detail.requestItemTitle}}</text>
    </view>
  </view>

  <view class="section" wx:if="{{detail.message}}">
    <text class="section-title">留言</text>
    <text class="message">{{detail.message}}</text>
  </view>

  <view class="actions" wx:if="{{detail.status === 1 && detail.targetUserId === userId}}">
    <button class="action-btn reject" bindtap="onReject">拒绝</button>
    <button class="action-btn confirm" bindtap="onConfirm">确认</button>
  </view>
</view>
