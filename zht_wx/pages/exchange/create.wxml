<!--pages/exchange/create.wxml-->
<view class="container">
  <view class="section">
    <text class="section-title">我提供的物品</text>
    <view class="item-selector" bindtap="selectOfferItem">
      <text wx:if="{{!offerItem}}" class="placeholder">请选择物品</text>
      <view wx:else class="selected-item">
        <image class="item-image" src="{{offerItem.images[0]}}" mode="aspectFill"></image>
        <text class="item-title">{{offerItem.title}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <text class="section-title">我想换的物品</text>
    <view class="item-info">
      <image class="item-image" src="{{requestItem.images[0]}}" mode="aspectFill"></image>
      <view class="item-detail">
        <text class="item-title">{{requestItem.title}}</text>
        <text class="item-desc">{{requestItem.description}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <text class="section-title">留言</text>
    <textarea class="message-input" placeholder="给 TA 说点什么吧..." value="{{message}}" bindinput="onMessageInput" maxlength="200" />
  </view>

  <button class="submit-btn" bindtap="onSubmit" loading="{{loading}}">发起交换</button>
</view>
