<!--pages/exchange/detail.wxml-->
<view class="container" wx:if="{{detail}}">
  <view class="status-bar status-{{detail.status}}">
    <text class="status-text">{{statusMap[detail.status]}}</text>
  </view>

  <view class="section">
    <text class="section-title">基本信息</text>
    <view class="info-row">
      <text class="label">交换单号:</text>
      <text>{{detail.exchangeNo}}</text>
    </view>
    <view class="info-row">
      <text class="label">创建时间:</text>
      <text>{{detail.createTime}}</text>
    </view>
    <view class="info-row" wx:if="{{detail.completeTime}}">
      <text class="label">完成时间:</text>
      <text>{{detail.completeTime}}</text>
    </view>
  </view>

  <view class="section">
    <text class="section-title">对方信息</text>
    <view class="user-info">
      <image class="user-avatar" src="{{detail.targetUserAvatar ? detail.targetUserAvatar : '/images/login/morentouxiang.png'}}" mode="aspectFill"></image>
      <view class="user-detail">
        <text class="user-nickname">{{detail.targetUserName ? detail.targetUserName : '未知用户'}}</text>
        <view class="user-credit">
          <text class="credit-label">信用分</text>
          <text class="credit-score">{{detail.targetUserCredit ? detail.targetUserCredit : 0}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <text class="section-title">物品信息</text>
    
    <!-- 提供的物品 -->
    <view class="item-detail">
      <view class="item-label">{{isApplicant ? '我提供的物品' : '对方提供的物品'}}</view>
      <view class="item-content">
        <image class="item-image" src="{{offerItem.image}}" mode="aspectFill" binderror="onImageError" data-type="offer"></image>
        <view class="item-info">
          <text class="item-title">{{offerItem.title}}</text>
        </view>
      </view>
    </view>
    
    <!-- 请求的物品 -->
    <view class="item-detail">
      <view class="item-label">{{isApplicant ? '我想换的物品' : '对方想换的物品'}}</view>
      <view class="item-content">
        <image class="item-image" src="{{requestItem.image}}" mode="aspectFill" binderror="onImageError" data-type="request"></image>
        <view class="item-info">
          <text class="item-title">{{requestItem.title}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{detail.message}}">
    <text class="section-title">留言信息</text>
    <text class="message">{{detail.message}}</text>
  </view>

  <!-- 评价信息 -->
  <view class="section" wx:if="{{review}}">
    <text class="section-title">评价信息</text>
    <view class="review-content">
      <view class="review-header">
        <image class="review-avatar" src="{{review.reviewerAvatar || '/images/login/morentouxiang.png'}}" mode="aspectFill"></image>
        <view class="review-info">
          <text class="review-name">{{review.reviewerName || '未知用户'}}</text>
          <view class="review-rating">
            <text class="star" wx:for="{{5}}" wx:key="*this">
              {{index < review.rating ? '★' : '☆'}}
            </text>
          </view>
        </view>
      </view>
      <text class="review-text">{{review.content || '暂无评价内容'}}</text>
      <text class="review-time">{{review.createTime}}</text>
    </view>
  </view>

  <view class="info-row" wx:if="{{detail.rejectReason}}" style="background:#fff; padding:16rpx 30rpx;">
    <text class="label">拒绝原因:</text>
    <text class="reject-reason" style="color:#f44336;">{{detail.rejectReason}}</text>
  </view>

  <!-- 待确认状态（status=0），且当前用户是物品主人 -->
  <view class="actions" wx:if="{{detail.status === 0 && !isApplicant}}">
    <button class="action-btn reject" bindtap="onReject">拒绝</button>
    <button class="action-btn confirm" bindtap="onConfirm">确认</button>
  </view>

  <!-- 已确认状态（status=1），且当前用户是申请人 -->
  <view class="actions" wx:if="{{detail.status === 1 && isApplicant}}">
    <button class="action-btn cancel" bindtap="onCancel">取消</button>
    <button class="action-btn complete" bindtap="onComplete">完成</button>
  </view>
</view>
