/* pages/exchange/detail.wxss */
.container { padding: 30rpx; background: #f5f5f5; min-height: 100vh; }
.status-bar { padding: 30rpx; border-radius: 16rpx; text-align: center; margin-bottom: 20rpx; }
.status-text { font-size: 36rpx; font-weight: bold; color: #ffffff; }
.status-0 { background: #ff9800; } /* 待确认 - 橙色 */
.status-1 { background: #2196f3; } /* 已确认 - 蓝色 */
.status-2 { background: #4caf50; } /* 已完成 - 绿色 */
.status-3 { background: #f44336; } /* 已拒绝 - 红色 */
.status-4 { background: #9e9e9e; } /* 已取消 - 灰色 */
.section { background: #ffffff; border-radius: 16rpx; padding: 30rpx; margin-bottom: 20rpx; }
.section-title { font-size: 30rpx; font-weight: bold; display: block; margin-bottom: 20rpx; }
.info-row, .item-row { display: flex; justify-content: space-between; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; font-size: 28rpx; }
.label { color: #999999; }
.message { font-size: 28rpx; color: #666666; line-height: 1.6; }

/* 物品详情样式 */
.item-detail { margin-bottom: 30rpx; }
.item-detail:last-child { margin-bottom: 0; }
.item-label { font-size: 28rpx; color: #999999; margin-bottom: 16rpx; }
.item-content { display: flex; align-items: center; background: #f9f9f9; border-radius: 12rpx; padding: 20rpx; }
.item-image { width: 120rpx; height: 120rpx; border-radius: 12rpx; margin-right: 20rpx; flex-shrink: 0; }
.item-info { flex: 1; min-width: 0; }
.item-title { font-size: 30rpx; color: #333; font-weight: 500; word-break: break-all; }
.user-info { display: flex; align-items: center; padding: 20rpx 0; }
.user-avatar { width: 100rpx; height: 100rpx; border-radius: 50%; margin-right: 20rpx; }
.user-detail { flex: 1; }
.user-nickname { font-size: 28rpx; font-weight: bold; display: block; margin-bottom: 10rpx; }
.user-credit { display: flex; align-items: center; gap: 10rpx; }
.credit-label { font-size: 24rpx; color: #999999; }
.credit-score { font-size: 24rpx; color: #ff9800; font-weight: bold; }
.actions { display: flex; gap: 20rpx; margin-top: 40rpx; }
.action-btn { flex: 1; height: 88rpx; border-radius: 44rpx; font-size: 30rpx; }
.reject { background: #ffffff; color: #ff4444; border: 1rpx solid #ff4444; }
.cancel { background: #ffffff; color: #ff9800; border: 1rpx solid #ff9800; }
.complete { background: #2196f3; color: #ffffff; border: 1rpx solid #2196f3; }
.confirm { background: #07c160; color: #ffffff; border: 1rpx solid #07c160; }
