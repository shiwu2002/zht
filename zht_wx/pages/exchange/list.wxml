<!--pages/exchange/list.wxml-->
<view class="container">
  <view class="tab-bar">
    <view class="tab-item {{currentTab === 0 ? 'active' : ''}}" bindtap="onTabChange" data-tab="0">全部</view>
    <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" bindtap="onTabChange" data-tab="1">待确认</view>
    <view class="tab-item {{currentTab === 2 ? 'active' : ''}}" bindtap="onTabChange" data-tab="2">进行中</view>
    <view class="tab-item {{currentTab === 3 ? 'active' : ''}}" bindtap="onTabChange" data-tab="3">已完成</view>
  </view>

  <view class="exchange-list">
    <view class="exchange-item" wx:for="{{exchangeList}}" wx:key="id" 
          data-id="{{item.id}}" bindtap="toDetail">
      <view class="exchange-header">
        <text class="exchange-no">交换单号：{{item.exchangeNo}}</text>
        <text class="exchange-status {{'status-' + item.status}}">{{statusMap[item.status]}}</text>
      </view>
      <view class="exchange-content">
        <view class="exchange-item-info">
          <text class="label">我提供的：</text>
          <text class="title">{{item.offerItemTitle}}</text>
        </view>
        <view class="exchange-arrow">⇄</view>
        <view class="exchange-item-info">
          <text class="label">我想换：</text>
          <text class="title">{{item.requestItemTitle}}</text>
        </view>
      </view>
      <view class="exchange-footer">
        <text class="time">{{item.createTime}}</text>
        <view class="actions" wx:if="{{item.status === 1}}">
          <button class="action-btn reject" catchtap="rejectExchange" data-id="{{item.id}}">拒绝</button>
          <button class="action-btn confirm" catchtap="confirmExchange" data-id="{{item.id}}">确认</button>
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{exchangeList.length === 0}}">
    <text>暂无交换记录</text>
  </view>
</view>
