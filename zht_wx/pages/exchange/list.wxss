/* pages/exchange/list.wxss */
.container {
  background: #f5f5f5;
  min-height: 100vh;
}

.tab-bar {
  display: flex;
  background: #ffffff;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666666;
  padding: 10rpx 0;
}

.tab-item.active {
  color: #07c160;
  font-weight: bold;
  border-bottom: 4rpx solid #07c160;
}

.exchange-list {
  padding: 0 30rpx;
}

.exchange-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.exchange-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.exchange-no {
  font-size: 24rpx;
  color: #999999;
}

.exchange-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.status-1 { color: #ff9900; background: #fff8e6; }
.status-2 { color: #07c160; background: #e8f9f0; }
.status-3 { color: #1890ff; background: #e6f7ff; }
.status-4 { color: #999999; background: #f5f5f5; }

.exchange-content {
  margin-bottom: 20rpx;
}

.exchange-item-info {
  margin-bottom: 16rpx;
}

.label {
  font-size: 24rpx;
  color: #999999;
}

.title {
  font-size: 28rpx;
  color: #333333;
}

.exchange-arrow {
  text-align: center;
  color: #07c160;
  font-size: 32rpx;
  margin: 10rpx 0;
}

.exchange-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.time {
  font-size: 24rpx;
  color: #999999;
}

.actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  border-radius: 30rpx;
}

.reject {
  background: #ffffff;
  color: #ff4444;
  border: 1rpx solid #ff4444;
}

.confirm {
  background: #07c160;
  color: #ffffff;
  border: 1rpx solid #07c160;
}

.empty {
  text-align: center;
  padding: 200rpx 0;
  color: #999999;
  font-size: 28rpx;
}
