/* pages/exchange/list.wxss */
.container { 
  padding: 20rpx; 
  background: #f5f5f5; 
  min-height: 100vh; 
}

.tab-bar {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #07c160;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #07c160;
  border-radius: 2rpx;
}

.exchange-list {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.exchange-item {
  border-bottom: 1px solid #f5f5f5;
  padding: 20rpx 0;
}

.exchange-item:last-child {
  border-bottom: none;
}

.exchange-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.exchange-no {
  font-size: 24rpx;
  color: #999999;
}

.exchange-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  background: #f5f5f5;
}

.exchange-status-1 {
  color: #ff9800;
  background: #fff3e0;
}

.exchange-status-2 {
  color: #2196f3;
  background: #e3f2fd;
}

.exchange-status-3 {
  color: #4caf50;
  background: #e8f5e9;
}

.exchange-status-4 {
  color: #9e9e9e;
  background: #f5f5f5;
}

.exchange-status-5 {
  color: #f44336;
  background: #ffebee;
}

.exchange-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.exchange-item-info {
  flex: 1;
}

.label {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-bottom: 8rpx;
}

.title {
  font-size: 28rpx;
  color: #333333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.exchange-arrow {
  font-size: 32rpx;
  color: #07c160;
  margin: 0 20rpx;
}

.exchange-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.time {
  font-size: 24rpx;
  color: #999999;
}

.actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
}

.action-btn.reject {
  background: #ffffff;
  color: #f44336;
  border: 1px solid #f44336;
}

.action-btn.confirm {
  background: #07c160;
  color: #ffffff;
  border: 1px solid #07c160;
}

.empty {
  text-align: center;
  padding: 100rpx 20rpx;
  color: #999999;
  font-size: 28rpx;
}
