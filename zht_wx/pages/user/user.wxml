<!--pages/user/user.wxml-->
<view class="container">
  <!-- 用户信息 -->
  <view class="user-header" bindtap="toEdit">
    <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
    <view class="user-info">
      <text class="nickname">{{userInfo.nickname || '点击登录'}}</text>
      <text class="credit">信用分：{{userInfo.creditScore || 0}}</text>
    </view>
    <text class="arrow">></text>
  </view>

  <!-- 数据统计 -->
  <view class="stats-row">
    <view class="stat-item" bindtap="toMyItems">
      <text class="stat-num">{{stats.publishCount || 0}}</text>
      <text class="stat-label">发布</text>
    </view>
    <view class="stat-item" bindtap="toFavorite">
      <text class="stat-num">{{stats.favoriteCount || 0}}</text>
      <text class="stat-label">收藏</text>
    </view>
    <view class="stat-item" bindtap="toExchange">
      <text class="stat-num">{{stats.exchangeCount || 0}}</text>
      <text class="stat-label">交换</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="toMyItems">
      <text class="menu-icon">📦</text>
      <text class="menu-text">我的发布</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="toExchange">
      <text class="menu-icon">🔄</text>
      <text class="menu-text">交换记录</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="toFavorite">
      <text class="menu-icon">⭐</text>
      <text class="menu-text">我的收藏</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="toMessage">
      <text class="menu-icon">💬</text>
      <text class="menu-text">消息中心</text>
      <text class="badge" wx:if="{{unreadCount > 0}}">{{unreadCount}}</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="toAddress">
      <text class="menu-icon">📍</text>
      <text class="menu-text">收货地址</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="toAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="onLogout" wx:if="{{isLogin}}">
      <text class="menu-icon">🚪</text>
      <text class="menu-text">退出登录</text>
      <text class="arrow">></text>
    </view>
  </view>
</view>
