<!--pages/user/edit.wxml-->
<view class="container">
  <view class="avatar-section" bindtap="updateAvatar">
    <image class="avatar" src="{{avatar}}" mode="aspectFill"></image>
    <text class="update-tip">点击更换头像</text>
  </view>

  <view class="form">
    <view class="form-item">
      <text class="label">昵称</text>
      <input class="input" value="{{nickname}}" bindinput="onNicknameInput" placeholder="请输入昵称" />
    </view>

    <view class="form-item">
      <text class="label">性别</text>
      <picker mode="selector" range="{{genders}}" value="{{genderIndex}}" bindchange="onGenderChange">
        <view class="picker">{{genders[genderIndex]}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">手机号</text>
      <view class="phone-row">
        <text class="phone">{{phone || '未绑定'}}</text>
        <button class="bind-btn" wx:if="{{!phone}}" bindtap="bindPhone">绑定</button>
      </view>
    </view>

    <view class="form-item">
      <text class="label">收货地址</text>
      <input class="input" value="{{address}}" bindinput="onAddressInput" placeholder="请输入收货地址" />
    </view>
  </view>

  <button class="save-btn" bindtap="onSave" loading="{{loading}}">保存</button>
</view>
