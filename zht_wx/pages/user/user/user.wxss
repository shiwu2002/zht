/* pages/user/user.wxss */
.container {
  background: #f5f5f5;
  min-height: 100vh;
}

.user-header {
  background: linear-gradient(135deg, #07c160, #06ad56);
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  position: relative;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-info {
  flex: 1;
  margin-left: 30rpx;
}

.nickname {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.credit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

.arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
}

.stats-card {
  background: #ffffff;
  margin: -40rpx 30rpx 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #07c160;
  display: block;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
  display: block;
}

.menu-section {
  background: #ffffff;
  margin-bottom: 30rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  position: relative;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon-img {
  width: 40rpx;
  height: 40rpx;
}

.menu-text {
  flex: 1;
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #333333;
}

.badge {
  background: #ff4d4f;
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 10rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #cccccc;
}

.logout-btn {
  margin: 30rpx;
  background: #ffffff;
  color: #ff4d4f;
  font-size: 28rpx;
  border-radius: 16rpx;
}
