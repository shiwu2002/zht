/* pages/user/user.wxss */
.container {
  background: #f3f3f3;
  min-height: 100vh;
}

/* 用户头部 */
.user-header {
  position: relative;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  padding: 80rpx 30rpx 120rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  margin-right: 30rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 16rpx;
}

.credit {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  display: flex;
  align-items: center;
}

.credit::before {
  content: '⭐';
  margin-right: 8rpx;
}

.arrow {
  color: rgba(255, 255, 255, 0.8);
  font-size: 36rpx;
}

/* 统计卡片 */
.stats-card {
  background: #ffffff;
  margin: -80rpx 30rpx 30rpx;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 10;
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.stat-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: -50%;
  top: 50%;
  transform: translateY(-50%);
  width: 1rpx;
  height: 60rpx;
  background: #f0f0f0;
}

.stat-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #07c160;
  margin-bottom: 12rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #999;
}

/* 菜单区块 */
.menu-section {
  background: #ffffff;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 36rpx 30rpx;
  position: relative;
  transition: background 0.2s;
}

.menu-item:active {
  background: #f8f8f8;
}

.menu-item:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 120rpx;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: #f5f5f5;
}

.menu-icon {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(7, 193, 96, 0.1);
  border-radius: 16rpx;
  margin-right: 24rpx;
  font-size: 32rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.badge {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff4444 100%);
  color: #ffffff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  margin-right: 20rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(255, 68, 68, 0.3);
}

.menu-arrow {
  color: #ccc;
  font-size: 36rpx;
}

/* 退出登录 */
.logout-btn {
  margin: 30rpx;
  height: 88rpx;
  background: #ffffff;
  color: #ff4444;
  border: 2rpx solid #ff4444;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.logout-btn:active {
  background: rgba(255, 68, 68, 0.1);
}
