/* pages/user/edit.wxss */
.container { padding: 30rpx; background: #f5f5f5; min-height: 100vh; }
.avatar-section { display: flex; flex-direction: column; align-items: center; background: #ffffff; border-radius: 16rpx; padding: 60rpx 0; margin-bottom: 20rpx; }
.avatar { width: 200rpx; height: 200rpx; border-radius: 50%; margin-bottom: 20rpx; }
.update-tip { font-size: 26rpx; color: #999999; }
.form { background: #ffffff; border-radius: 16rpx; padding: 30rpx; }
.form-item { margin-bottom: 40rpx; }
.label { font-size: 28rpx; font-weight: bold; display: block; margin-bottom: 20rpx; }
.input, .picker { width: 100%; height: 88rpx; background: #f5f5f5; border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; box-sizing: border-box; }
.phone-row { display: flex; justify-content: space-between; align-items: center; height: 88rpx; background: #f5f5f5; border-radius: 12rpx; padding: 0 20rpx; }
.bind-btn { padding: 12rpx 32rpx; font-size: 26rpx; background: #07c160; color: #ffffff; border-radius: 30rpx; }
.save-btn { height: 88rpx; background: #07c160; color: #ffffff; border-radius: 44rpx; font-size: 32rpx; margin-top: 60rpx; }
