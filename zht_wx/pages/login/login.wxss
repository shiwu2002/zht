/* pages/login/login.wxss */
.login-container {
  padding: 40rpx;
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.login-header {
  text-align: center;
  margin-bottom: 80rpx;
  margin-top: 100rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.login-form {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-button {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #f5f5f5;
  border: 4rpx solid #667eea;
  padding: 0;
  margin-bottom: 30rpx;
}

.avatar-preview {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999999;
  font-size: 24rpx;
}

.iconfont {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.default-avatars {
  width: 100%;
}

.tips {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 15rpx;
  text-align: center;
}

.avatar-list {
  display: flex;
  justify-content: space-around;
  flex-wrap: wrap;
}

.default-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin: 10rpx;
  border: 4rpx solid transparent;
  transition: all 0.3s;
}

.default-avatar.selected {
  border-color: #667eea;
  transform: scale(1.1);
}

.nickname-section {
  position: relative;
}

.nickname-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
}

.nickname-display .placeholder {
  color: #999999;
  font-size: 28rpx;
}

.nickname-display text:not(.placeholder):not(.edit-icon) {
  color: #333333;
  font-size: 28rpx;
}

.edit-icon {
  font-size: 32rpx;
}

.nickname-input {
  width: 100%;
  padding: 24rpx 30rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
  font-size: 28rpx;
  box-sizing: border-box;
}

.submit-button {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  margin-top: 60rpx;
  border: none;
}

.submit-button[loading] {
  opacity: 0.8;
}