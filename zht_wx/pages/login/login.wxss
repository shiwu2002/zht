/* pages/login/login.wxss */
.container {
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #07c160 0%, #ffffff 40%);
  position: relative;
}

.logo {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  z-index: 2;
}

.logo-img {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 20rpx;
  border-radius: 50%;
  box-shadow: 0 10rpx 20rpx rgba(0, 0, 0, 0.1);
}

.logo-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.form {
  width: 100%;
  max-width: 600rpx;
  margin-bottom: 40rpx;
  z-index: 2;
}

.form-item {
  margin-bottom: 40rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  background: #ffffff;
  border-radius: 44rpx;
  padding: 0 40rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid #f0f0f0;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.05);
}

.input:focus {
  border-color: #07c160;
  box-shadow: 0 4rpx 15rpx rgba(7, 193, 96, 0.2);
}

.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.avatar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 10rpx 20rpx rgba(0, 0, 0, 0.1);
  object-fit: cover;
}

.nickname {
  margin-top: 20rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #ffffff;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.3);
}

.avatar-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  color: #07c160;
  border-radius: 44rpx;
  font-size: 28rpx;
  border: 2rpx solid #f0f0f0;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.05);
}

.avatar-btn::after {
  border: none;
}

.phone-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  color: #07c160;
  border-radius: 44rpx;
  font-size: 28rpx;
  border: 2rpx solid #f0f0f0;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.05);
}

.phone-btn::after {
  border: none;
}

.btn-hover {
  background-color: #f8f8f8;
  opacity: 0.8;
}

.agree {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #ffffff;
  margin-bottom: 40rpx;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.3);
  z-index: 2;
}

.agree-label {
  display: flex;
  align-items: center;
}

.agree-checkbox {
  transform: scale(0.8);
  margin-right: 10rpx;
}

.link {
  color: #ffffff;
  text-decoration: underline;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(to right, #07c160, #00aa55);
  color: #ffffff;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 20rpx rgba(7, 193, 96, 0.3);
  margin-bottom: 30rpx;
}

.login-btn::after {
  border: none;
}

.login-btn[disabled] {
  background: #cccccc;
}

.tips {
  font-size: 24rpx;
  color: #ffffff;
  text-align: center;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.3);
  z-index: 2;
  line-height: 1.5;
}

.tips .link {
  display: inline-block;
  margin: 0 10rpx;
}

/* 添加背景装饰元素 */
.container::before {
  content: '';
  position: absolute;
  top: -50rpx;
  left: -50rpx;
  right: -50rpx;
  bottom: -50rpx;
  background: inherit;
  filter: blur(50rpx);
  z-index: 1;
}

/* Loading效果 */
.loading-text {
  display: flex;
  align-items: center;
  justify-content: center;
}