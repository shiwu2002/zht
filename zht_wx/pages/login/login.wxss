/* pages/login/login.wxss */
.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.login-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.login-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.login-subtitle {
  font-size: 28rpx;
  color: #999;
}

.avatar-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.avatar-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
  display: flex;
  justify-content: center;
  align-items: center;
}

.avatar-btn::after {
  border: none;
  width: auto;
}

.avatar-container {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid #07c160;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.avatar {
  width: 100%;
  height: 100%;
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(0, 0, 0, 0.6);
  padding: 12rpx;
  text-align: center;
}

.avatar-edit .icon-camera {
  color: #fff;
  font-size: 32rpx;
}

.avatar-placeholder {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 4rpx dashed #ccc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.avatar-placeholder .icon-camera {
  font-size: 48rpx;
  color: #ccc;
  margin-bottom: 8rpx;
}

.placeholder-text {
  font-size: 24rpx;
  color: #999;
}

.default-avatars {
  margin-top: 40rpx;
  text-align: center;
}

.avatar-tip {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 16rpx;
}

.default-avatar-list {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.default-avatar-item {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 2rpx solid #eee;
}

.default-avatar {
  width: 100%;
  height: 100%;
}

.nickname-section {
  width: 100%;
  margin-bottom: 80rpx;
}

.nickname-input-container {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.nickname-input-container .nickname-label {
  font-size: 28rpx;
  color: #999;
  margin-right: 16rpx;
  white-space: nowrap;
}

.nickname-input {
  flex: 1;
  font-size: 32rpx;
  height: 48rpx;
  line-height: 48rpx;
  box-sizing: border-box;
}

.confirm-btn {
  background-color: #07c160;
  color: #fff;
  border-radius: 8rpx;
}

.nickname-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #fff;
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.nickname-label {
  font-size: 28rpx;
  color: #999;
}

.nickname-text {
  font-size: 32rpx;
  color: #333;
  flex: 1;
  margin-left: 16rpx;
}

.edit-icon {
  font-size: 32rpx;
  color: #07c160;
}

.login-btn {
  width: 100%;
  background-color: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 28rpx 0;
  border-radius: 50rpx;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}
