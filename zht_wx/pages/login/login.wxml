<!--pages/login/login.wxml-->
<view class="login-container">
  <view class="login-header">
    <text class="title">欢迎加入</text>
    <text class="subtitle">设置您的个人信息</text>
  </view>

  <view class="login-form">
    <!-- 头像选择 -->
    <view class="form-item">
      <text class="label">头像</text>
      <view class="avatar-section">
        <button open-type="chooseAvatar" class="avatar-button" hover-class="none">
          <image 
            wx:if="{{avatar}}" 
            src="{{avatar}}" 
            class="avatar-preview"
          />
          <view wx:else class="avatar-placeholder">
            <text class="iconfont">&#xe603;</text>
            <text>选择头像</text>
          </view>
        </button>
        
        <!-- 默认头像列表 -->
        <view class="default-avatars">
          <text class="tips">或选择默认头像：</text>
          <view class="avatar-list">
            <image 
              wx:for="{{defaultAvatars}}" 
              wx:key="*this"
              src="{{item}}" 
              class="default-avatar {{avatar === item ? 'selected' : ''}}"
              data-avatar="{{item}}"
              bindtap="onSelectDefaultAvatar"
            />
          </view>
        </view>
      </view>
    </view>

    <!-- 昵称输入 -->
    <view class="form-item">
      <text class="label">昵称</text>
      <view class="nickname-section">
        <view wx:if="{{!isEditingNickname}}" class="nickname-display" bindtap="onEditNickname">
          <text wx:if="{{nickname}}">{{nickname}}</text>
          <text wx:else class="placeholder">点击输入昵称</text>
          <text class="edit-icon">✏️</text>
        </view>
        <input 
          wx:else 
          type="nickname" 
          class="nickname-input" 
          placeholder="请输入昵称"
          value="{{nickname}}"
          bindinput="onNicknameInput"
          bindblur="onConfirmNickname"
          confirm-type="done"
          bindconfirm="onConfirmNickname"
          focus="{{isEditingNickname}}"
        />
      </view>
    </view>

    <!-- 完成按钮 -->
    <button class="submit-button" bindtap="onComplete" loading="{{isLoading}}">
      完成设置并登录
    </button>
  </view>
</view>