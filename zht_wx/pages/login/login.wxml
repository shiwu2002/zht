<!--pages/login/login.wxml-->
<view class="login-container">
  <view class="login-header">
    <text class="login-title">欢迎登录</text>
    <text class="login-subtitle">登录后享受更多服务</text>
  </view>

  <view class="avatar-section">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <view class="avatar-container" wx:if="{{avatar}}">
        <image class="avatar" src="{{avatar}}" mode="aspectFill" />
        <view class="avatar-edit">
          <text class="iconfont icon-camera"></text>
        </view>
      </view>
      
      <view class="avatar-placeholder" wx:else>
        <text class="iconfont icon-camera"></text>
        <text class="placeholder-text">点击选择头像</text>
      </view>
    </button>

    <view class="default-avatars" wx:if="{{!avatar}}">
      <text class="avatar-tip">或选择默认头像</text>
      <view class="default-avatar-list">
        <view 
          class="default-avatar-item" 
          wx:for="{{defaultAvatars}}" 
          wx:key="*this"
          data-avatar="{{item}}"
          catchtap="onSelectDefaultAvatar"
        >
          <image class="default-avatar" src="{{item}}" mode="aspectFill" />
        </view>
      </view>
    </view>
  </view>

  <view class="nickname-section">
    <view class="nickname-input-container" wx:if="{{isEditingNickname}}">
      <text class="nickname-label">昵称:</text>
      <input 
        class="nickname-input" 
        type="text"
        placeholder="请输入昵称" 
        value="{{nickname}}"
        bindinput="onNicknameInput"
        bindblur="onConfirmNickname"
        confirm-type="done"
        bindconfirm="onConfirmNickname"
        focus="{{isEditingNickname}}"
      />
      
    </view>
    
    <view class="nickname-display" wx:else catchtap="onEditNickname">
      <text class="nickname-label">昵称：</text>
      <text class="nickname-text">{{nickname || '点击设置昵称'}}</text>
      <text class="iconfont icon-edit edit-icon"></text>
    </view>
  </view>

  <button class="login-btn" catchtap="onComplete">登录</button>
</view>
