<!--pages/index/index.wxml-->
<view class="container">
  
  <!-- 顶部搜索栏 -->
  <view class="search-bar">
    <view class="search-input" bindtap="toSearch">
      <image class="search-icon" src="/images/carouseChart/sousuo.png" mode="aspectFit"></image>
      <text class="placeholder">搜索闲置物品</text>
    </view>
    <view class="publish-btn" bindtap="toPublish">
      <text>+</text>
    </view>
  </view>

  <!-- 轮播图 -->
  <swiper class="banner-swiper" indicator-dots="{{true}}" autoplay="{{true}}" interval="{{3000}}" duration="{{500}}">
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <image class="banner-image" src="{{item.image}}" mode="aspectFill" bindtap="onBannerTap" data-url="{{item.url}}"></image>
    </swiper-item>
  </swiper>

  <!-- 分类导航 -->
  <view class="category-section card">
    <view class="category-grid">
      <view class="category-item" data-id="0" bindtap="onCategoryTap">
        <image class="category-icon-img {{currentCategory === 0 ? 'active' : ''}}" src="/images/classify/other.png" mode="aspectFit"></image>
        <text class="category-name {{currentCategory === 0 ? 'active' : ''}}">全部</text>
      </view>
      <view class="category-item" data-id="1" bindtap="onCategoryTap">
        <image class="category-icon-img {{currentCategory === 1 ? 'active' : ''}}" src="/images/classify/book.png" mode="aspectFit"></image>
        <text class="category-name {{currentCategory === 1 ? 'active' : ''}}">教材</text>
      </view>
      <view class="category-item" data-id="2" bindtap="onCategoryTap">
        <image class="category-icon-img {{currentCategory === 2 ? 'active' : ''}}" src="/images/classify/digital.png" mode="aspectFit"></image>
        <text class="category-name {{currentCategory === 2 ? 'active' : ''}}">数码</text>
      </view>
      <view class="category-item" data-id="3" bindtap="onCategoryTap">
        <image class="category-icon-img {{currentCategory === 3 ? 'active' : ''}}" src="/images/classify/clothes.png" mode="aspectFit"></image>
        <text class="category-name {{currentCategory === 3 ? 'active' : ''}}">服饰</text>
      </view>
      <view class="category-item" data-id="4" bindtap="onCategoryTap">
        <image class="category-icon-img {{currentCategory === 4 ? 'active' : ''}}" src="/images/classify/home.png" mode="aspectFit"></image>
        <text class="category-name {{currentCategory === 4 ? 'active' : ''}}">生活</text>
      </view>
    </view>
  </view>

  <!-- 推荐标题 -->
  <view class="section-header">
    <view class="header-left">
      <view class="header-line"></view>
      <text class="header-title">热门推荐</text>
    </view>
    <view class="header-more" bindtap="showMore">
      <text>更多</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 物品列表 -->
  <view class="item-list">
    <view class="item-card card" wx:for="{{itemList}}" wx:key="id" 
          data-id="{{item.id}}" bindtap="toDetail">
      <image class="item-image" src="{{item.images[0]}}" mode="aspectFill"></image>
      <view class="item-info">
        <text class="item-title">{{item.title}}</text>
        <view class="item-price-row">
          <text class="item-price">¥ {{item.price}}</text>
          <text class="item-exchange-type" wx:if="{{item.exchangeType === 1}}">可交换</text>
        </view>
        <view class="item-meta">
          <text class="item-location">📍 {{item.location}}</text>
          <text class="item-favorite">❤️ {{item.favoriteCount}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
  <view class="no-more" wx:if="{{!hasMore && itemList.length > 0}}">
    <text>— 没有更多了 —</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && itemList.length === 0}}">
    <text>暂无物品</text>
  </view>

</view>
