/* pages/index/index.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  display: flex;
  align-items: center;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 30rpx;
}

.placeholder {
  margin-left: 16rpx;
  color: #999999;
  font-size: 28rpx;
}

.publish-btn {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: #07c160;
  color: #ffffff;
  border-radius: 50%;
  margin-left: 20rpx;
  font-size: 40rpx;
}

.category-nav {
  display: flex;
  overflow-x: auto;
  padding: 20rpx 0;
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.category-item {
  flex-shrink: 0;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: #666666;
}

.category-item.active {
  color: #07c160;
  font-weight: bold;
}

.item-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.item-card {
  width: 48%;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.item-image {
  width: 100%;
  height: 360rpx;
}

.item-info {
  padding: 20rpx;
}

.item-title {
  font-size: 28rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-desc {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-meta {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #999999;
}

.load-more, .no-more {
  text-align: center;
  padding: 30rpx;
  color: #999999;
  font-size: 24rpx;
}
